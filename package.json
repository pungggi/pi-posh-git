{
  "name": "pi-posh-git",
  "version": "1.1.3",
  "description": "posh-git style persistent git status for pi. Displays branch, ahead/behind, staged/unstaged counts, and stash count — always visible in the footer.",
  "keywords": [
    "pi-package",
    "pi",
    "pi.dev",
    "pi-extension",
    "git",
    "posh-git",
    "status",
    "widget"
  ],
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pungggi/pi-posh-git.git"
  },
  "homepage": "https://github.com/pungggi/pi-posh-git#readme",
  "bugs": {
    "url": "https://github.com/pungggi/pi-posh-git/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "image": "https://raw.githubusercontent.com/pungggi/pi-posh-git/master/screenshot.png"
  }
}
